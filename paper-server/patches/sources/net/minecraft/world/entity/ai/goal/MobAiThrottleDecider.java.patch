+public final class MobAiThrottleDecider {
+    private static final Logger LOGGER = LogUtils.getLogger();
+    private static final File ITONG_CONFIG_FILE = new File("config", "itong.yml");
+    private static final int VANILLA_SELECTOR_INTERVAL = 2;
+    private static final int THROTTLED_SELECTOR_INTERVAL = 4;
+    private static final int ZOMBIE_PATH_RECALCULATION_EXTRA_COOLDOWN = 6;
+    private static final int SKELETON_TARGET_CHECK_INTERVAL = 20;
+    private static final double NEAR_PLAYER_RADIUS = 24.0;
+    private static final double FAR_PLAYER_RADIUS = 48.0;
+    private static final double SWARM_RADIUS = 12.0;
+    private static final int SWARM_SIZE_THRESHOLD = 5;
+    private static final int RELOAD_CHECK_INTERVAL_TICKS = 200;
+    private static final AsyncSwarmDensityTracker ASYNC_SWARM_TRACKER = new AsyncSwarmDensityTracker();
+    private static final MobSettings ZOMBIE_DEFAULT_SETTINGS = new MobSettings(
+        true,
+        true,
