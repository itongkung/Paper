+package net.minecraft.world.entity.ai.goal;
+
+import net.minecraft.world.entity.Mob;
+import net.minecraft.world.entity.monster.Creeper;
+import net.minecraft.world.entity.monster.skeleton.AbstractSkeleton;
+import net.minecraft.world.entity.monster.zombie.Zombie;
+
+public final class MobAiThrottleDecider {
+    private static final int VANILLA_SELECTOR_INTERVAL = 2;
+    private static final int THROTTLED_SELECTOR_INTERVAL = 4;
+    private static final double NEAR_PLAYER_RADIUS = 24.0;
+    private static final double FAR_PLAYER_RADIUS = 48.0;
+    private static final double SWARM_RADIUS = 12.0;
+    private static final int SWARM_SIZE_THRESHOLD = 5;
+
+    private MobAiThrottleDecider() {
+    }
+
+    public static int goalSelectorInterval(final Mob mob) {
+        return shouldThrottleFarMobAi(mob) ? THROTTLED_SELECTOR_INTERVAL : VANILLA_SELECTOR_INTERVAL;
+    }
+
+    public static boolean shouldThrottleFarMobAi(final Mob mob) {
+        if (!supportsFarMobAiThrottle(mob)) {
+            return false;
+        }
+        if (mob.level().hasNearbyAlivePlayer(mob.getX(), mob.getY(), mob.getZ(), NEAR_PLAYER_RADIUS)) {
+            return false;
+        }
+        if (!mob.level().hasNearbyAlivePlayer(mob.getX(), mob.getY(), mob.getZ(), FAR_PLAYER_RADIUS)) {
+            return true;
+        }
+        return isInSwarm(mob);
+    }
+
+    private static boolean supportsFarMobAiThrottle(final Mob mob) {
+        return mob instanceof Zombie || mob instanceof AbstractSkeleton || mob instanceof Creeper;
+    }
+
+    private static boolean isInSwarm(final Mob mob) {
+        return mob.level()
+                .getEntitiesOfClass(Mob.class, mob.getBoundingBox().inflate(SWARM_RADIUS), nearby -> nearby != mob && nearby.getType() == mob.getType())
+                .size() >= SWARM_SIZE_THRESHOLD;
+    }
+}
