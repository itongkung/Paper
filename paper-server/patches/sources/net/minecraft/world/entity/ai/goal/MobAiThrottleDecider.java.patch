+    private static final MobSettings DISABLED_SETTINGS = new MobSettings(false, false, VANILLA_SELECTOR_INTERVAL, false, 0, false, 0, false, 0, false);
+    private static volatile ConfigState cachedConfig = ConfigState.defaults();
