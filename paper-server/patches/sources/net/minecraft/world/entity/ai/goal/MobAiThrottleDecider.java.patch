+
+    private MobAiThrottleDecider() {
+    }
+
+    public static int goalSelectorInterval(final Mob mob) {
+        ConfigState state = configFor(mob);
+        MobSettings settings = settingsFor(mob, state);
+        if (!settings.farMobAiThrottleEnabled() || !shouldThrottleFarMobAi(mob, state, settings)) {
+            return VANILLA_SELECTOR_INTERVAL;
+        }
+        return Math.max(VANILLA_SELECTOR_INTERVAL, settings.farMobAiThrottleTickRate());
+    }
+
+    public static int zombiePathRecalculationExtraCooldown(final Mob mob) {
+        ConfigState state = configFor(mob);
+        MobSettings settings = settingsFor(mob, state);
+        if (!settings.zombiePathRecalculationEnabled() || !shouldThrottleZombiePathRecalculation(mob, state, settings)) {
+            return 0;
+        }
+        return Math.max(0, settings.zombiePathRecalculationExtraCooldown());
+    }
+
+    public static int skeletonTargetCheckInterval(final Mob mob) {
+        ConfigState state = configFor(mob);
+        MobSettings settings = settingsFor(mob, state);
+        if (!settings.skeletonTargetCheckEnabled() || !shouldThrottleSkeletonTargetChecks(mob, state, settings)) {
+            return 0;
+        }
+        return Math.max(0, settings.skeletonTargetCheckInterval());
+    }
+
+    public static boolean shouldThrottleFarMobAi(final Mob mob) {
+        ConfigState state = configFor(mob);
+        return shouldThrottleFarMobAi(mob, state, settingsFor(mob, state));
+    }
+
+    public static boolean shouldSkipCollisionPush(final Mob mob) {
+        ConfigState state = configFor(mob);
+        MobSettings settings = settingsFor(mob, state);
+        return settings.disableCollisionPushWhenThrottled() && shouldThrottleFarMobAi(mob, state, settings);
+    }
+
+    public static boolean shouldSkipVillagerBrainTick(final Villager villager) {
+        ConfigState state = configFor(villager);
+        MobSettings settings = settingsFor(villager, state);
+        if (!settings.villagerBrainThrottleEnabled() || !shouldThrottleFarMobAi(villager, state, settings)) {
+            return false;
+        }
+        int interval = Math.max(2, settings.villagerBrainTickRate());
+        long tick = villager.level().getGameTime() + villager.getId();
+        return tick % interval != 0;
+    }
+
+    private static boolean shouldThrottleFarMobAi(final Mob mob, final ConfigState state, final MobSettings settings) {
+        if (!state.enabled() || !settings.enabled()) {
+            return false;
+        }
+        MobGroup mobGroup = mobGroup(mob);
+        if (mobGroup != MobGroup.OTHER) {
+            // ส่ง snapshot ไปให้ worker คำนวณความหนาแน่นนอกเธรดหลัก
+            ASYNC_SWARM_TRACKER.submitSample(mob, mobGroup);
+        }
+        if (state.nearPlayerRadius() > 0.0 && mob.level().hasNearbyAlivePlayer(mob.getX(), mob.getY(), mob.getZ(), state.nearPlayerRadius())) {
+            return false;
+        }
+        if (state.farPlayerRadius() <= 0.0 || !mob.level().hasNearbyAlivePlayer(mob.getX(), mob.getY(), mob.getZ(), state.farPlayerRadius())) {
+            return true;
+        }
+        return isInSwarm(mob, mobGroup, state.swarmRadius(), state.swarmSizeThreshold());
+    }
+
+    private static boolean shouldThrottleZombiePathRecalculation(final Mob mob, final ConfigState state, final MobSettings settings) {
+        return mob instanceof Zombie && shouldThrottleFarMobAi(mob, state, settings);
+    }
+
+    private static boolean shouldThrottleSkeletonTargetChecks(final Mob mob, final ConfigState state, final MobSettings settings) {
+        return mob instanceof AbstractSkeleton && shouldThrottleFarMobAi(mob, state, settings);
+    }
+
+    private static boolean isInSwarm(final Mob mob, final MobGroup mobGroup, final double swarmRadius, final int swarmSizeThreshold) {
+        if (mobGroup == MobGroup.OTHER || swarmRadius <= 0.0 || swarmSizeThreshold <= 0) {
+            return false;
+        }
+        return ASYNC_SWARM_TRACKER.isDense(mob, mobGroup, swarmRadius, swarmSizeThreshold);
+    }
+
+    private static MobGroup mobGroup(final Mob mob) {
+        if (mob instanceof Villager) {
+            return MobGroup.VILLAGER;
+        }
+        if (mob instanceof Zombie) {
+            return MobGroup.ZOMBIE;
+        }
+        if (mob instanceof AbstractSkeleton) {
+            return MobGroup.SKELETON;
+        }
+        if (mob instanceof Creeper) {
+            return MobGroup.CREEPER;
+        }
+        if (mob instanceof Animal) {
+            return MobGroup.ANIMAL;
+        }
+        return MobGroup.OTHER;
+    }
+
+    private static ConfigState configFor(final Mob mob) {
+        long gameTime = mob.level().getGameTime();
+        ConfigState snapshot = cachedConfig;
+        if (gameTime < nextReloadCheckTick) {
+            return snapshot;
+        }
+        synchronized (MobAiThrottleDecider.class) {
+            if (gameTime < nextReloadCheckTick) {
+                return cachedConfig;
+            }
+            reloadConfigIfNeeded();
+            snapshot = cachedConfig;
+            nextReloadCheckTick = gameTime + Math.max(20L, snapshot.reloadCheckIntervalTicks());
+            return snapshot;
+        }
+    }
+
+    private static MobSettings settingsFor(final Mob mob, final ConfigState state) {
+        if (mob instanceof Villager) {
+            return state.villager();
+        }
+        if (mob instanceof Animal) {
+            return state.animal();
+        }
+        if (mob instanceof Zombie) {
+            return state.zombie();
+        }
+        if (mob instanceof AbstractSkeleton) {
+            return state.skeleton();
+        }
+        if (mob instanceof Creeper) {
+            return state.creeper();
+        }
+        return DISABLED_SETTINGS;
+    }
+
+    private static void reloadConfigIfNeeded() {
+        try {
+            ensureConfigFile();
+            long lastModified = ITONG_CONFIG_FILE.lastModified();
+            if (configLastModified == lastModified && configLastModified != Long.MIN_VALUE) {
+                return;
+            }
+
+            YamlConfiguration config = YamlConfiguration.loadConfiguration(ITONG_CONFIG_FILE);
+            YamlConfiguration defaults = createDefaultConfig();
+            config.setDefaults(defaults);
+            config.options().copyDefaults(true);
+            config.save(ITONG_CONFIG_FILE);
+
+            cachedConfig = ConfigState.from(config);
+            configLastModified = ITONG_CONFIG_FILE.lastModified();
+        } catch (IOException ex) {
+            LOGGER.warn("Failed to load {}", ITONG_CONFIG_FILE.getPath(), ex);
+            cachedConfig = ConfigState.defaults();
+        }
+    }
+
+    private static void ensureConfigFile() throws IOException {
+        File parent = ITONG_CONFIG_FILE.getParentFile();
+        if (parent != null && !parent.exists() && !parent.mkdirs() && !parent.exists()) {
+            throw new IOException("Failed to create directory: " + parent.getAbsolutePath());
+        }
+        if (!ITONG_CONFIG_FILE.exists()) {
+            createDefaultConfig().save(ITONG_CONFIG_FILE);
+        }
+    }
+
+    private static YamlConfiguration createDefaultConfig() {
+        YamlConfiguration defaults = new YamlConfiguration();
+        defaults.options().header("""
+            iTong AI throttling config (simple mode)
+            Use mobs.<type>.ai-tick-rate for far/swarm throttling.
+            Legacy keys are still supported for backward compatibility.
+            """);
+        defaults.set("global.enabled", true);
+        defaults.set("global.reload-check-interval-ticks", RELOAD_CHECK_INTERVAL_TICKS);
+        defaults.set("global.near-player-radius", NEAR_PLAYER_RADIUS);
+        defaults.set("global.always-throttle-radius", FAR_PLAYER_RADIUS);
+        defaults.set("global.swarm-radius", SWARM_RADIUS);
+        defaults.set("global.swarm-size-threshold", SWARM_SIZE_THRESHOLD);
+
+        writeMobDefaults(defaults, "mobs.zombie", ZOMBIE_DEFAULT_SETTINGS);
+        writeMobDefaults(defaults, "mobs.skeleton", SKELETON_DEFAULT_SETTINGS);
+        writeMobDefaults(defaults, "mobs.creeper", CREEPER_DEFAULT_SETTINGS);
+        writeMobDefaults(defaults, "mobs.animal", ANIMAL_DEFAULT_SETTINGS);
+        writeMobDefaults(defaults, "mobs.villager", VILLAGER_DEFAULT_SETTINGS);
+        return defaults;
+    }
+
+    private static void writeMobDefaults(final YamlConfiguration config, final String path, final MobSettings settings) {
+        config.set(path + ".enabled", settings.enabled());
+        config.set(path + ".ai-throttle-enabled", settings.farMobAiThrottleEnabled());
+        config.set(path + ".ai-tick-rate", settings.farMobAiThrottleTickRate());
+        config.set(path + ".zombie-path-extra-cooldown", settings.zombiePathRecalculationExtraCooldown());
+        config.set(path + ".skeleton-target-check-interval", settings.skeletonTargetCheckInterval());
+        config.set(path + ".villager-brain-tick-rate", settings.villagerBrainTickRate());
+        config.set(path + ".disable-collision-push-when-throttled", settings.disableCollisionPushWhenThrottled());
+    }
+
+    private static MobSettings readMobSettings(final YamlConfiguration config, final String path, final MobSettings defaults) {
+        int aiTickRate = readInt(config, defaults.farMobAiThrottleTickRate(), path + ".ai-tick-rate", path + ".far-mob-ai-throttle.tick-rate");
+        boolean aiEnabled = readBoolean(config, defaults.farMobAiThrottleEnabled(), path + ".ai-throttle-enabled", path + ".far-mob-ai-throttle.enabled");
+
+        int zombieExtraCooldown = readInt(config, defaults.zombiePathRecalculationExtraCooldown(), path + ".zombie-path-extra-cooldown", path + ".zombie-path-recalculation.extra-cooldown");
+        boolean zombieEnabled = readBoolean(config, defaults.zombiePathRecalculationEnabled(), path + ".zombie-path-extra-cooldown-enabled", path + ".zombie-path-recalculation.enabled");
+        if (!containsAny(config, path + ".zombie-path-extra-cooldown-enabled", path + ".zombie-path-recalculation.enabled")
+            && containsAny(config, path + ".zombie-path-extra-cooldown", path + ".zombie-path-recalculation.extra-cooldown")) {
+            zombieEnabled = zombieExtraCooldown > 0;
+        }
+
+        int skeletonCheckInterval = readInt(config, defaults.skeletonTargetCheckInterval(), path + ".skeleton-target-check-interval", path + ".skeleton-target-check.interval");
+        boolean skeletonEnabled = readBoolean(config, defaults.skeletonTargetCheckEnabled(), path + ".skeleton-target-check-enabled", path + ".skeleton-target-check.enabled");
+        if (!containsAny(config, path + ".skeleton-target-check-enabled", path + ".skeleton-target-check.enabled")
+            && containsAny(config, path + ".skeleton-target-check-interval", path + ".skeleton-target-check.interval")) {
+            skeletonEnabled = skeletonCheckInterval > 0;
+        }
+
+        int villagerBrainTickRate = readInt(config, defaults.villagerBrainTickRate(), path + ".villager-brain-tick-rate", path + ".villager-brain.tick-rate");
+        boolean villagerBrainEnabled = readBoolean(config, defaults.villagerBrainThrottleEnabled(), path + ".villager-brain-enabled", path + ".villager-brain.enabled");
+        if (!containsAny(config, path + ".villager-brain-enabled", path + ".villager-brain.enabled")
+            && containsAny(config, path + ".villager-brain-tick-rate", path + ".villager-brain.tick-rate")) {
+            villagerBrainEnabled = villagerBrainTickRate > 0;
+        }
+
+        return new MobSettings(
+            readBoolean(config, defaults.enabled(), path + ".enabled"),
+            aiEnabled,
+            aiTickRate,
+            zombieEnabled,
+            zombieExtraCooldown,
+            skeletonEnabled,
+            skeletonCheckInterval,
+            villagerBrainEnabled,
+            villagerBrainTickRate,
+            readBoolean(
+                config,
+                defaults.disableCollisionPushWhenThrottled(),
+                path + ".disable-collision-push-when-throttled",
+                path + ".collision-push.disable-when-throttled"
+            )
+        );
+    }
+
+    private static boolean containsAny(final YamlConfiguration config, final String... paths) {
+        for (final String path : paths) {
+            if (config.contains(path)) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    private static boolean readBoolean(final YamlConfiguration config, final boolean defaultValue, final String... paths) {
+        for (final String path : paths) {
+            if (config.contains(path)) {
+                return config.getBoolean(path, defaultValue);
+            }
+        }
+        return defaultValue;
+    }
+
+    private static int readInt(final YamlConfiguration config, final int defaultValue, final String... paths) {
+        for (final String path : paths) {
+            if (config.contains(path)) {
+                return config.getInt(path, defaultValue);
+            }
+        }
+        return defaultValue;
+    }
+
+    private static double readDouble(final YamlConfiguration config, final double defaultValue, final String... paths) {
+        for (final String path : paths) {
+            if (config.contains(path)) {
+                return config.getDouble(path, defaultValue);
+            }
+        }
+        return defaultValue;
+    }
+
+    private static MobSettings readMobSettingsWithFallback(
+        final YamlConfiguration config,
+        final MobSettings defaults,
+        final String primaryPath,
+        final String fallbackPath
+    ) {
+        if (config.contains(primaryPath)) {
+            return readMobSettings(config, primaryPath, defaults);
+        }
+        if (config.contains(fallbackPath)) {
+            return readMobSettings(config, fallbackPath, defaults);
+        }
+        return readMobSettings(config, primaryPath, defaults);
+    }
+
+    private record MobSettings(
+        boolean enabled,
+        boolean farMobAiThrottleEnabled,
+        int farMobAiThrottleTickRate,
+        boolean zombiePathRecalculationEnabled,
+        int zombiePathRecalculationExtraCooldown,
+        boolean skeletonTargetCheckEnabled,
+        int skeletonTargetCheckInterval,
+        boolean villagerBrainThrottleEnabled,
+        int villagerBrainTickRate,
+        boolean disableCollisionPushWhenThrottled
+    ) {
+    }
+
+    private record ConfigState(
+        boolean enabled,
+        int reloadCheckIntervalTicks,
+        double nearPlayerRadius,
+        double farPlayerRadius,
+        double swarmRadius,
+        int swarmSizeThreshold,
+        MobSettings zombie,
+        MobSettings skeleton,
+        MobSettings creeper,
+        MobSettings animal,
+        MobSettings villager
+    ) {
+        static ConfigState defaults() {
+            return new ConfigState(
+                true,
+                RELOAD_CHECK_INTERVAL_TICKS,
+                NEAR_PLAYER_RADIUS,
+                FAR_PLAYER_RADIUS,
+                SWARM_RADIUS,
+                SWARM_SIZE_THRESHOLD,
+                ZOMBIE_DEFAULT_SETTINGS,
+                SKELETON_DEFAULT_SETTINGS,
+                CREEPER_DEFAULT_SETTINGS,
+                ANIMAL_DEFAULT_SETTINGS,
+                VILLAGER_DEFAULT_SETTINGS
+            );
+        }
+
+        static ConfigState from(final YamlConfiguration config) {
+            return new ConfigState(
+                readBoolean(config, true, "global.enabled"),
+                Math.max(20, readInt(config, RELOAD_CHECK_INTERVAL_TICKS, "global.reload-check-interval-ticks")),
+                Math.max(0.0, readDouble(config, NEAR_PLAYER_RADIUS, "global.near-player-radius")),
+                Math.max(0.0, readDouble(config, FAR_PLAYER_RADIUS, "global.always-throttle-radius", "global.far-player-radius")),
+                Math.max(0.0, readDouble(config, SWARM_RADIUS, "global.swarm-radius")),
+                Math.max(0, readInt(config, SWARM_SIZE_THRESHOLD, "global.swarm-size-threshold")),
+                readMobSettings(config, "mobs.zombie", ZOMBIE_DEFAULT_SETTINGS),
+                readMobSettings(config, "mobs.skeleton", SKELETON_DEFAULT_SETTINGS),
+                readMobSettings(config, "mobs.creeper", CREEPER_DEFAULT_SETTINGS),
+                readMobSettingsWithFallback(config, ANIMAL_DEFAULT_SETTINGS, "mobs.animal", "mobs.animals"),
+                readMobSettings(config, "mobs.villager", VILLAGER_DEFAULT_SETTINGS)
+            );
+        }
+    }
+
+    private enum MobGroup {
+        OTHER,
+        ZOMBIE,
+        SKELETON,
+        CREEPER,
+        ANIMAL,
+        VILLAGER
+    }
+
+    private static final class AsyncSwarmDensityTracker {
+        private static final int CELL_SIZE = 8;
+        private static final long CLEANUP_INTERVAL_NANOS = 1_000_000_000L;
+        private static final long STALE_SAMPLE_NANOS = 20_000_000_000L;
+        private final ConcurrentLinkedQueue<MobSample> pending = new ConcurrentLinkedQueue<>();
+        private final ConcurrentHashMap<Long, Integer> cellCounts = new ConcurrentHashMap<>();
+        private final ConcurrentHashMap<Long, Integer> lastSubmittedTick = new ConcurrentHashMap<>();
+        private final Thread worker;
+
+        AsyncSwarmDensityTracker() {
+            this.worker = new Thread(this::run, "iTong-MobSwarm-Worker");
+            this.worker.setDaemon(true);
+            this.worker.setUncaughtExceptionHandler((thread, throwable) -> LOGGER.error("iTong mob swarm worker crashed", throwable));
+            this.worker.start();
+        }
+
+        void submitSample(final Mob mob, final MobGroup group) {
+            int worldId = System.identityHashCode(mob.level());
+            long entityKey = composeEntityKey(worldId, mob.getId());
+            int currentTick = mob.tickCount;
+            Integer previousTick = this.lastSubmittedTick.put(entityKey, currentTick);
+            if (previousTick != null && previousTick.intValue() == currentTick) {
+                return;
+            }
+            // เก็บเฉพาะตำแหน่งย่อส่วนเป็น cell เพื่อลดต้นทุนการคำนวณ
+            this.pending.offer(new MobSample(entityKey, worldId, group.ordinal(), toCell(mob.getX()), toCell(mob.getZ()), System.nanoTime()));
+        }
+
+        boolean isDense(final Mob mob, final MobGroup group, final double radius, final int threshold) {
+            int worldId = System.identityHashCode(mob.level());
+            int centerCellX = toCell(mob.getX());
+            int centerCellZ = toCell(mob.getZ());
+            int cellRadius = Math.max(0, (int)Math.ceil(radius / CELL_SIZE));
+            int count = 0;
+            int groupId = group.ordinal();
+            // อ่านจาก cache ที่ worker อัปเดตไว้แทนการค้นเอนติตี้รอบตัวทุกครั้ง
+            for (int dx = -cellRadius; dx <= cellRadius; ++dx) {
+                for (int dz = -cellRadius; dz <= cellRadius; ++dz) {
+                    long key = composeCellKey(worldId, groupId, centerCellX + dx, centerCellZ + dz);
+                    count += this.cellCounts.getOrDefault(key, 0);
+                    if (count >= threshold) {
+                        return true;
+                    }
+                }
+            }
+            return false;
+        }
+
+        private void run() {
+            Map<Long, TrackedMob> tracked = new java.util.HashMap<>();
+            long lastCleanup = System.nanoTime();
+            for (;;) {
+                boolean didWork = false;
+                MobSample sample;
+                // worker รวมข้อมูลตำแหน่งเข้าตารางความหนาแน่นนอกเธรดหลัก
+                while ((sample = this.pending.poll()) != null) {
+                    didWork = true;
+                    TrackedMob current = tracked.get(sample.entityKey());
+                    long nextCell = composeCellKey(sample.worldId(), sample.groupId(), sample.cellX(), sample.cellZ());
+                    if (current == null) {
+                        tracked.put(sample.entityKey(), new TrackedMob(sample.worldId(), sample.groupId(), nextCell, sample.seenNanos()));
+                        this.adjustCell(nextCell, 1);
+                    } else {
+                        if (current.cellKey != nextCell || current.groupId != sample.groupId() || current.worldId != sample.worldId()) {
+                            this.adjustCell(current.cellKey, -1);
+                            this.adjustCell(nextCell, 1);
+                            current.worldId = sample.worldId();
+                            current.groupId = sample.groupId();
+                            current.cellKey = nextCell;
+                        }
+                        current.lastSeenNanos = sample.seenNanos();
+                    }
+                }
+
+                long now = System.nanoTime();
+                if (now - lastCleanup >= CLEANUP_INTERVAL_NANOS) {
+                    didWork = true;
+                    Iterator<Map.Entry<Long, TrackedMob>> iterator = tracked.entrySet().iterator();
+                    // ลบข้อมูลเก่าที่ไม่อัปเดตแล้ว ป้องกัน map โตไม่หยุด
+                    while (iterator.hasNext()) {
+                        Map.Entry<Long, TrackedMob> entry = iterator.next();
+                        TrackedMob trackedMob = entry.getValue();
+                        if (now - trackedMob.lastSeenNanos > STALE_SAMPLE_NANOS) {
+                            this.adjustCell(trackedMob.cellKey, -1);
+                            this.lastSubmittedTick.remove(entry.getKey());
+                            iterator.remove();
+                        }
+                    }
+                    lastCleanup = now;
+                }
+
+                if (!didWork) {
+                    LockSupport.parkNanos(500_000L);
+                }
+            }
+        }
+
+        private void adjustCell(final long cellKey, final int delta) {
+            this.cellCounts.compute(cellKey, (key, current) -> {
+                int next = (current == null ? 0 : current.intValue()) + delta;
